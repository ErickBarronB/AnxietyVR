--- !u!114 &193340448
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 193340438}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 56936231851a8f64fa970ddb098ed369, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueLines:
  - line: "Cada d\xEDa, millones de personas libran batallas que nadie puede ver."
    typingSpeed: 0.05
  - line: No todas las heridas son visibles.
    typingSpeed: 0.05
  - line: "La ansiedad no siempre grita. A veces susurra todos los d\xEDas, hasta
      que olvidamos c\xF3mo se sent\xEDa el silencio."
    typingSpeed: 0.05
  - line: "Pero recuerda: no est\xE1s solo."
    typingSpeed: 0.05
  - line: "Hay personas dispuestas a escucharte, comprenderte y acompa\xF1arte en
      el camino."
    typingSpeed: 0.05
  - line: "Buscar ayuda no es una se\xF1al de debilidad, sino un acto de valent\xEDa."
    typingSpeed: 0.05
  - line: Si sientes que esta batalla te supera, consulta a un profesional de la
      salud mental.
    typingSpeed: 0.05
  - line: 0800-333-1665  Salud Mental
    typingSpeed: 0.05
  - line: "Atenci\xF3n gratuita, disponible las 24 horas, los 7 d\xEDas de la semana,
      con psic\xF3logos y psiquiatras."
    typingSpeed: 0.05
  - line: "Porque ninguna batalla deber\xEDa librarse en soledad."
    typingSpeed: 0.05
  delayAfterDialogue: 3
  audioSource: {fileID: 193340439}
  dialogueAudio: {fileID: 8300000, guid: 3672ee7d86b688b4ab60b61fff8ff367, type: 3}
